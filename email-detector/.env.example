# ==============================================================================
# AI Email Security Detector - Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in real values before running.
# NEVER commit .env with real secrets to version control.
# ==============================================================================

# Flask
FLASK_ENV=production
SECRET_KEY=change-this-to-a-random-32-character-string
APP_PORT=5000

# Redis
REDIS_PASSWORD=change-this-to-a-secure-password

# Nginx
NGINX_PORT=80
NGINX_SSL_PORT=443

# ML Model Settings
CONFIDENCE_THRESHOLD=70.0
MAX_EMAIL_LENGTH=50000
MAX_CONTENT_LENGTH=1048576

# Logging
LOG_LEVEL=INFO

# Optional
DATABASE_URL=
BUILD_DATE=
VERSION=1.0.0
VCS_REF=
