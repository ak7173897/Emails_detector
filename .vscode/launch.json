{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Email Detector",
      "type": "python",
      "request": "launch",
      "module": "flask",
      "cwd": "${workspaceFolder}/email-detector",
      "args": ["run", "--host=0.0.0.0", "--port=5000"],
      "envFile": "${workspaceFolder}/email-detector/.env",
      "env": {
        "FLASK_APP": "src.wsgi:application",
        "FLASK_ENV": "development"
      },
      "console": "integratedTerminal",
      "justMyCode": true,
      "jinja": true
    }
  ]
}
